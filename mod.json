{
    "geode": "5.5.3",
    "gd": {
        "win": "2.2081",
        "mac": "2.2081",
        "android": "2.2081"
    },
    "id": "yourname.auto-dodge",
    "name": "Auto Dodge",
    "version": "2.0.0",
    "developer": "yourname",
    "description": "Full trajectory-based auto-dodge for all game modes.",
    "settings": {
        "enabled": {
            "name": "Enable Auto Dodge",
            "type": "bool",
            "default": true
        },
        "trajectory-steps": {
            "name": "Trajectory Simulation Steps",
            "type": "int",
            "default": 90,
            "min": 30,
            "max": 240
        },
        "look-ahead-px": {
            "name": "Look-Ahead Distance",
            "type": "float",
            "default": 80.0,
            "min": 20.0,
            "max": 200.0
        },
        "use-orbs": {
            "name": "Use Jump Orbs",
            "type": "bool",
            "default": true
        },
        "use-dash-orbs": {
            "name": "Use Dash Orbs",
            "type": "bool",
            "default": true
        },
        "mode-cube": { "name": "Enable: Cube", "type": "bool", "default": true },
        "mode-ship": { "name": "Enable: Ship", "type": "bool", "default": true },
        "mode-ball": { "name": "Enable: Ball", "type": "bool", "default": true },
        "mode-wave": { "name": "Enable: Wave", "type": "bool", "default": true },
        "mode-robot": { "name": "Enable: Robot", "type": "bool", "default": true },
        "mode-swing": { "name": "Enable: Swing", "type": "bool", "default": true },
        "show-overlay": { "name": "Show HUD Overlay", "type": "bool", "default": true },
        "show-trajectory": { "name": "Show Trajectory Debug", "type": "bool", "default": false }
    }
}
